; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes in [] on its own line
;   param=value ; each parameter goes on its own line

config_version=5

[application]

config/name="fruit_view"
config/features=PackedStringArray("4.3", "Forward Plus")
config/main_scene="res://scenes/main.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)

[head_tracker]

mode="mouse_look"
mouse_sensitivity=0.1
opentrack_port=4242

[video]

source="local_file"
local_file_path=""
rtsp_url="rtsp://192.168.1.100:8554/stream"
sidecar_port=9001
sidecar_python="python3"

[control]

vehicle_host="192.168.1.100"
vehicle_port=9000
keepalive_interval_sec=0.5

[telemetry]

port=9002

[input_map]

throttle_axis=1
steering_axis=0
